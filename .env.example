# Compose-level secrets — copy to .env and fill in real values
# The .env file is gitignored

# Runtime environment (Development | Staging | Production)
ASPNETCORE_ENVIRONMENT=Production

# Postgres (used by the in-compose postgres for dev environments;
# the new droplet uses DigitalOcean Managed Postgres instead)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=ApplyRush

# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=

# Elasticsearch / Kibana (shared password)
ELASTIC_PASSWORD=

# Claude (Anthropic) API key — client-provided
CLAUDE_API_KEY=

# SendGrid API key — client-provided, used by EmailService
SENDGRID_API_KEY=